  bookTitle: 
  spreads:
  - layout: {fileID: 6211519498159910813, guid: cc6383de98fd6294388821de6cde789f, type: 3}
    textA: 'The local animals have been changing over the last few years. Mainly
      the deer, but they are not deer anymore.


      Maybe they kept the form to
      prey easier?


      I will try to keep a log of these beasts in this book. '
    textB: 
    textC: 
    textD: 
    imageA: {fileID: 865804816067458902, guid: c613b4c540c83ac4ba00ad0bee065134, type: 3}
    imageB: {fileID: 0}
